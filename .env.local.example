NEXT_PUBLIC_TITLE=Clariata
NEXT_PUBLIC_DESCRIPTION=Clariata
NEXT_PUBLIC_DOMAIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:64489

# authentication
NEXT_PUBLIC_STORAGE_AUTH_FLAG=clariata_authorized
NEXT_PUBLIC_STORAGE_AUTH_KEY=clariata_token
NEXT_PUBLIC_STORAGE_TOKEN_EXPIRATION_DATE_KEY=token_expiration_date
# Token refresh interval - in sec.
NEXT_PUBLIC_STORAGE_TOKEN_REFRESH_INTERVAL=3600

# Observability / logging (client-side; safe to publish ONLY as placeholders)
NEXT_PUBLIC_LOGROCKET_APP=
NEXT_PUBLIC_BUGSNAG_API_KEY=

# Resource downloads (S3)
# WARNING: Do NOT use long-lived AWS keys in the browser for production.
# Prefer a backend endpoint that returns a short-lived pre-signed URL.
NEXT_PUBLIC_AWS_REGION=
NEXT_PUBLIC_AWS_BUCKET_NAME=
NEXT_PUBLIC_AWS_ACCESS_KEY=
NEXT_PUBLIC_AWS_SECRET_KEY=