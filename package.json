  "scripts": {
    "debug": "cross-env NODE_OPTIONS='--inspect' next dev",
    "dev": "next dev",
    "devsite": "next dev -p 80",
    "dev:env": "env-cmd -f .env.local next dev",
    "build": "next build",
    "build-dev": "env-cmd -f .env.dev next build",
    "build-staging": "yarn run write-version && env-cmd -f .env.staging next build",
    "build-prod": "yarn run write-version && env-cmd -f .env.production next build",
    "build:env": "yarn run write-version && env-cmd -f .env.$ENVIRONMENT next build",
    "start": "next start -p 80",
    "start-dev": "next start NODE_ENV=dev",
    "start-custom": "cross-env NODE_ENV=production node server.js",
    "lint:js": "eslint -c ./.eslintrc.js ./src/**/*{ts,tsx}",
    "lint:js:fix": "eslint -c ./.eslintrc.js --fix ./src/**/*{ts,tsx}",
    "lint:ts": "tslint -c ./tslint.json -p ./tsconfig.json",
    "lint:ts:fix": "tslint -c ./tslint.json --fix -p ./tsconfig.json",
    "lint:css": "stylelint \"./src/**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"./src/**/*.{css,scss}\" --fix",
    "write-version": "node utils/write-version.js .next/static/version.json",
    "bump-version": "node utils/bump-version.js",
    "generate:specs": "npx @manifoldco/swagger-to-ts swagger.json -o src/types/swagger.d.ts"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "browser": {
    "html-pdf": false,
    "child_process": false
  },
  "devDependencies": {
    "@types/node": "^14.18.12",
    "@types/react": "^16.14.23",
    "@typescript-eslint/eslint-plugin": "^4.2.0",
    "@typescript-eslint/parser": "^4.2.0",
    "babel-plugin-styled-components": "^1.13.3",
    "cross-env": "^7.0.3",
    "eslint-config-airbnb": "18.2.0",
    "eslint-config-airbnb-typescript": "^10.0.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-prettier": "^3.1.4",
    "prettier": "^2.1.2",
    "typescript": "^3.7.7"
  }
